<Window x:Class="DongNoti.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:DongNoti.Converters"
        Title="DongNoti - 알람 관리"
        Height="640"
        Width="960"
        MinHeight="560"
        MinWidth="820"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/app.ico"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown"
        Background="#F4F6F8"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <converters:CategoryColorConverter x:Key="CategoryColorConverter"/>
        <converters:IsPastAlarmConverter x:Key="IsPastAlarmConverter"/>
        <converters:MainWindowDdayDisplayConverter x:Key="MainWindowDdayDisplayConverter"/>

        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FAFBFC"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DDE3EA"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextSubtleBrush" Color="#667085"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2F80ED"/>

        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="ModernRaisedButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="68"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1F6FD6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#185ABC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#E5EAF0"/>
                                <Setter Property="BorderBrush" Value="#E5EAF0"/>
                                <Setter Property="Foreground" Value="#98A2B3"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernOutlinedButton" TargetType="Button" BasedOn="{StaticResource ModernRaisedButton}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#2F80ED"/>
            <Setter Property="BorderBrush" Value="#B7D4FF"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F6FF"/>
                    <Setter Property="BorderBrush" Value="#82B8FF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#DCEBFF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFFFFF"/>
                    <Setter Property="Foreground" Value="#98A2B3"/>
                    <Setter Property="BorderBrush" Value="#E5EAF0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SmallGhostButton" TargetType="Button" BasedOn="{StaticResource ModernOutlinedButton}">
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#C9D2DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource ModernComboBoxStyle}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="7,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="Transparent"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#F0F6FF"/>
                                <Setter Property="Foreground" Value="#1F6FD6"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#E7F0FF"/>
                                <Setter Property="Foreground" Value="#185ABC"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#98A2B3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleDataGridTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="CenteredDataGridTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="#E9EEF5"
                                    BorderBrush="#DDE3EA"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Padding="3"
                                    HorizontalAlignment="Left">
                                <TabPanel IsItemsHost="True"
                                          Background="Transparent"
                                          KeyboardNavigation.TabIndex="1"/>
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabChrome"
                                Background="Transparent"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="#F8FBFF"/>
                                <Setter Property="Foreground" Value="#2F80ED"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#FBFCFE"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="RowHeight" Value="36"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EDF1F5"/>
            <Setter Property="VerticalGridLinesBrush" Value="#EDF1F5"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Height" Value="32"/>
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="Background" Value="#F3F6FA"/>
                        <Setter Property="Foreground" Value="#667085"/>
                        <Setter Property="BorderBrush" Value="#DDE3EA"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="BorderBrush" Value="#EDF1F5"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E7F0FF"/>
                                <Setter Property="Foreground" Value="#1F2937"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1F2937"
                CornerRadius="6"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="DongNoti"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock Text="다음 알람:"
                                   FontSize="11"
                                   Foreground="#D1D9E6"
                                   Margin="0,0,6,0"/>
                        <TextBlock x:Name="NextAlarmText"
                                   Text="없음"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#8BC1FF"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock x:Name="StatusText"
                           Grid.Column="1"
                           Text="준비됨"
                           FontSize="12"
                           Foreground="#D1D9E6"
                           VerticalAlignment="Center"
                           Margin="18,0,0,0"/>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource ModernCard}"
                Margin="0,10,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <WrapPanel x:Name="ToolbarPanel" Grid.Row="0">
                    <Button x:Name="AddAlarmButton"
                            Content="+ 추가"
                            Click="AddAlarm_Click"
                            Style="{StaticResource ModernRaisedButton}"
                            Margin="0,0,6,6"/>
                    <Button x:Name="CloneButton"
                            Content="복제"
                            Click="Clone_Click"
                            Style="{StaticResource ModernOutlinedButton}"
                            Margin="0,0,6,6"/>
                    <Button x:Name="EditButton"
                            Content="수정"
                            Click="EditAlarm_Click"
                            IsEnabled="False"
                            Style="{StaticResource ModernOutlinedButton}"
                            Margin="0,0,6,6"/>
                    <Button x:Name="DeleteButton"
                            Content="삭제"
                            Click="DeleteAlarm_Click"
                            IsEnabled="False"
                            Style="{StaticResource ModernOutlinedButton}"
                            Margin="0,0,6,6"/>
                    <Button x:Name="OrganizeButton"
                            Content="정리"
                            Click="OrganizeButton_Click"
                            Style="{StaticResource ModernOutlinedButton}"
                            Margin="0,0,12,6">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="OrganizeContextMenu">
                                <MenuItem Header="지난 항목 삭제">
                                    <MenuItem Header="알람 삭제" Tag="Alarm" Click="DeletePastAlarms_Click"/>
                                    <MenuItem Header="Dday 삭제" Tag="Dday" Click="DeletePastDdays_Click"/>
                                    <MenuItem Header="알람 및 Dday 모두 삭제" Tag="All" Click="DeletePastAlarmsAndDdays_Click"/>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="모두 삭제">
                                    <MenuItem Header="알람 삭제" Tag="Alarm" Click="DeleteAlarms_Click"/>
                                    <MenuItem Header="Dday 삭제" Tag="Dday" Click="DeleteDdays_Click"/>
                                    <MenuItem Header="알람 및 Dday 모두 삭제" Tag="All" Click="DeleteAll_Click"/>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="모두 활성화">
                                    <MenuItem Header="알람 활성화" Tag="Alarm" Click="EnableAlarms_Click"/>
                                    <MenuItem Header="Dday 활성화" Tag="Dday" Click="EnableDdays_Click"/>
                                    <MenuItem Header="알람 및 Dday 모두 활성화" Tag="All" Click="EnableAll_Click"/>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="모두 비활성화">
                                    <MenuItem Header="알람 비활성화" Tag="Alarm" Click="DisableAlarms_Click"/>
                                    <MenuItem Header="Dday 비활성화" Tag="Dday" Click="DisableDdays_Click"/>
                                    <MenuItem Header="알람 및 Dday 모두 비활성화" Tag="All" Click="DisableAll_Click"/>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <Button Content="설정"
                            Click="Settings_Click"
                            Style="{StaticResource ModernOutlinedButton}"
                            Margin="0,0,6,6"/>
                    <Button x:Name="DdayWindowToggleButton"
                            Content="Dday 창"
                            Click="DdayWindowToggle_Click"
                            Style="{StaticResource ModernOutlinedButton}"
                            Margin="0,0,6,6"/>
                    <Button Content="통계"
                            Click="Statistics_Click"
                            Style="{StaticResource ModernOutlinedButton}"
                            Margin="0,0,6,6"/>
                    <Button x:Name="FocusModeButton"
                            Content="집중 모드"
                            Click="FocusMode_Click"
                            Style="{StaticResource ModernRaisedButton}"
                            Margin="0,0,0,6"/>
                </WrapPanel>

                <Grid Grid.Row="1" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchTextBox"
                                 TextChanged="SearchTextBox_TextChanged"
                                 ToolTip="검색"/>
                        <Button x:Name="ClearSearchButton"
                                Grid.Column="1"
                                Content="×"
                                Click="ClearSearch_Click"
                                Width="28"
                                Style="{StaticResource SmallGhostButton}"
                                Margin="4,0,0,0"
                                Visibility="Collapsed"/>
                    </Grid>

                    <ComboBox x:Name="FilterComboBox"
                              Grid.Column="2"
                              SelectionChanged="FilterComboBox_SelectionChanged">
                        <ComboBoxItem Content="전체" Tag="All" IsSelected="True"/>
                        <ComboBoxItem Content="알람만" Tag="AlarmOnly"/>
                        <ComboBoxItem Content="Dday만" Tag="DdayOnly"/>
                        <ComboBoxItem Content="활성" Tag="Enabled"/>
                        <ComboBoxItem Content="비활성" Tag="Disabled"/>
                        <ComboBoxItem Content="반복 없음" Tag="None"/>
                        <ComboBoxItem Content="매일" Tag="Daily"/>
                        <ComboBoxItem Content="매주" Tag="Weekly"/>
                        <ComboBoxItem Content="매월" Tag="Monthly"/>
                        <ComboBoxItem Content="매년" Tag="Yearly"/>
                    </ComboBox>

                    <ComboBox x:Name="CategoryFilterComboBox"
                              Grid.Column="4"
                              SelectionChanged="CategoryFilterComboBox_SelectionChanged">
                        <ComboBoxItem Content="전체" Tag="All" IsSelected="True"/>
                    </ComboBox>
                </Grid>
            </Grid>
        </Border>

        <TabControl Grid.Row="2">
            <TabItem Header="알람">
                <Border Style="{StaticResource ModernCard}" Padding="0" Margin="0,10,0,0">
                    <Grid>
                        <StackPanel x:Name="EmptyStatePanel"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock Text="알람이 없습니다"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#98A2B3"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <DataGrid x:Name="AlarmsDataGrid"
                                  Style="{StaticResource CompactDataGridStyle}"
                                  SelectionChanged="AlarmsDataGrid_SelectionChanged"
                                  MouseDoubleClick="AlarmsDataGrid_MouseDoubleClick"
                                  CellEditEnding="AlarmsDataGrid_CellEditEnding"
                                  PreviewKeyDown="DataGrid_PreviewKeyDown">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="MinHeight" Value="36"/>
                                    <Setter Property="Background" Value="#FFFFFF"/>
                                    <Setter Property="BorderBrush" Value="#EDF1F5"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F4F8FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E7F0FF"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsTemporary}" Value="True">
                                            <Setter Property="Foreground" Value="#98A2B3"/>
                                            <Setter Property="FontStyle" Value="Italic"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Converter={StaticResource IsPastAlarmConverter}}" Value="True">
                                            <Setter Property="Foreground" Value="#98A2B3"/>
                                            <Setter Property="Opacity" Value="0.72"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="긴급도" Width="74" IsReadOnly="True"
                                                        SortMemberPath="PrioritySortKey" CanUserSort="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="PriorityBadge"
                                                    CornerRadius="8"
                                                    Padding="6,2"
                                                    Background="#EEF2F6"
                                                    HorizontalAlignment="Center"
                                                    Height="22"
                                                    VerticalAlignment="Center">
                                                <TextBlock x:Name="PriorityLabel"
                                                           Text="보통"
                                                           FontSize="11"
                                                           Foreground="#536276"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Priority}" Value="Low">
                                                    <Setter TargetName="PriorityLabel" Property="Text" Value="낮음"/>
                                                    <Setter TargetName="PriorityLabel" Property="Foreground" Value="#667085"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priority}" Value="Normal">
                                                    <Setter TargetName="PriorityBadge" Property="Background" Value="#E7F0FF"/>
                                                    <Setter TargetName="PriorityLabel" Property="Text" Value="보통"/>
                                                    <Setter TargetName="PriorityLabel" Property="Foreground" Value="#1F6FD6"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priority}" Value="High">
                                                    <Setter TargetName="PriorityBadge" Property="Background" Value="#FFF4D8"/>
                                                    <Setter TargetName="PriorityLabel" Property="Text" Value="높음"/>
                                                    <Setter TargetName="PriorityLabel" Property="Foreground" Value="#B7791F"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priority}" Value="Critical">
                                                    <Setter TargetName="PriorityBadge" Property="Background" Value="#FFE4E1"/>
                                                    <Setter TargetName="PriorityLabel" Property="Text" Value="긴급"/>
                                                    <Setter TargetName="PriorityLabel" Property="Foreground" Value="#D92D20"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="카테고리" Width="96" IsReadOnly="True"
                                                        SortMemberPath="CategoryDisplay" CanUserSort="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8"
                                                    Padding="6,2"
                                                    Background="{Binding CategoryDisplay, Converter={StaticResource CategoryColorConverter}, ConverterParameter=BadgeBackground}"
                                                    BorderBrush="{Binding CategoryDisplay, Converter={StaticResource CategoryColorConverter}, ConverterParameter=BadgeBorderBrush}"
                                                    BorderThickness="1"
                                                    HorizontalAlignment="Center"
                                                    Height="22"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CategoryDisplay}"
                                                           FontSize="11"
                                                           Foreground="{Binding CategoryDisplay, Converter={StaticResource CategoryColorConverter}, ConverterParameter=BadgeForeground}"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="제목" Binding="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Width="*"
                                                    ElementStyle="{StaticResource TitleDataGridTextStyle}"/>
                                <DataGridTextColumn Header="날짜" Binding="{Binding DateTime, StringFormat=yyyy-MM-dd}" Width="112"
                                                    ElementStyle="{StaticResource CenteredDataGridTextStyle}"/>
                                <DataGridTextColumn Header="시간" Binding="{Binding DateTime, StringFormat=HH:mm}" Width="68" IsReadOnly="True"
                                                    ElementStyle="{StaticResource CenteredDataGridTextStyle}"/>
                                <DataGridTextColumn Header="반복" Binding="{Binding RepeatTypeString}" Width="74"
                                                    ElementStyle="{StaticResource CenteredDataGridTextStyle}"/>
                                <DataGridCheckBoxColumn Header="활성" Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" Width="56">
                                    <DataGridCheckBoxColumn.ElementStyle>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <EventSetter Event="Click" Handler="AlarmToggle_Click"/>
                                        </Style>
                                    </DataGridCheckBoxColumn.ElementStyle>
                                </DataGridCheckBoxColumn>
                                <DataGridCheckBoxColumn Header="Dday" Binding="{Binding AutoRegisterAsDday, UpdateSourceTrigger=PropertyChanged}" Width="62">
                                    <DataGridCheckBoxColumn.ElementStyle>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <EventSetter Event="Click" Handler="AutoDdayToggle_Click"/>
                                        </Style>
                                    </DataGridCheckBoxColumn.ElementStyle>
                                </DataGridCheckBoxColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="D-Day">
                <Border Style="{StaticResource ModernCard}" Padding="0" Margin="0,10,0,0">
                    <Grid>
                        <StackPanel x:Name="DdayEmptyStatePanel"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock Text="D-Day가 없습니다"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#98A2B3"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <DataGrid x:Name="DdaysDataGrid"
                                  Style="{StaticResource CompactDataGridStyle}"
                                  SelectionChanged="DdaysDataGrid_SelectionChanged"
                                  MouseDoubleClick="DdaysDataGrid_MouseDoubleClick"
                                  PreviewKeyDown="DataGrid_PreviewKeyDown">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="MinHeight" Value="36"/>
                                    <Setter Property="Background" Value="{Binding CategoryDisplay, Converter={StaticResource CategoryColorConverter}, ConverterParameter=RowBackground}"/>
                                    <Setter Property="BorderBrush" Value="#EDF1F5"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F4F8FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E7F0FF"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding Converter={StaticResource IsPastAlarmConverter}}" Value="True">
                                            <Setter Property="Foreground" Value="#98A2B3"/>
                                            <Setter Property="FontStyle" Value="Italic"/>
                                            <Setter Property="Opacity" Value="0.72"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="D-Day" Width="88" IsReadOnly="True"
                                                        SortMemberPath="DaysRemaining" CanUserSort="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource MainWindowDdayDisplayConverter}}"
                                                       FontSize="15"
                                                       Foreground="#1F6FD6"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="목표일" Binding="{Binding TargetDate, StringFormat=yyyy-MM-dd}" Width="112" IsReadOnly="True"
                                                    ElementStyle="{StaticResource CenteredDataGridTextStyle}"/>

                                <DataGridTemplateColumn Header="긴급도" Width="74" IsReadOnly="True"
                                                        SortMemberPath="PrioritySortKey" CanUserSort="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="PriorityBadge"
                                                    CornerRadius="8"
                                                    Padding="6,2"
                                                    Background="#EEF2F6"
                                                    HorizontalAlignment="Center"
                                                    Height="22"
                                                    VerticalAlignment="Center">
                                                <TextBlock x:Name="PriorityLabel"
                                                           Text="보통"
                                                           FontSize="11"
                                                           Foreground="#536276"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Priority}" Value="Low">
                                                    <Setter TargetName="PriorityLabel" Property="Text" Value="낮음"/>
                                                    <Setter TargetName="PriorityLabel" Property="Foreground" Value="#667085"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priority}" Value="Normal">
                                                    <Setter TargetName="PriorityBadge" Property="Background" Value="#E7F0FF"/>
                                                    <Setter TargetName="PriorityLabel" Property="Text" Value="보통"/>
                                                    <Setter TargetName="PriorityLabel" Property="Foreground" Value="#1F6FD6"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priority}" Value="High">
                                                    <Setter TargetName="PriorityBadge" Property="Background" Value="#FFF4D8"/>
                                                    <Setter TargetName="PriorityLabel" Property="Text" Value="높음"/>
                                                    <Setter TargetName="PriorityLabel" Property="Foreground" Value="#B7791F"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priority}" Value="Critical">
                                                    <Setter TargetName="PriorityBadge" Property="Background" Value="#FFE4E1"/>
                                                    <Setter TargetName="PriorityLabel" Property="Text" Value="긴급"/>
                                                    <Setter TargetName="PriorityLabel" Property="Foreground" Value="#D92D20"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="카테고리" Width="96" IsReadOnly="True"
                                                        SortMemberPath="CategoryDisplay" CanUserSort="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8"
                                                    Padding="6,2"
                                                    Background="{Binding CategoryDisplay, Converter={StaticResource CategoryColorConverter}, ConverterParameter=BadgeBackground}"
                                                    BorderBrush="{Binding CategoryDisplay, Converter={StaticResource CategoryColorConverter}, ConverterParameter=BadgeBorderBrush}"
                                                    BorderThickness="1"
                                                    HorizontalAlignment="Center"
                                                    Height="22"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CategoryDisplay}"
                                                           FontSize="11"
                                                           Foreground="{Binding CategoryDisplay, Converter={StaticResource CategoryColorConverter}, ConverterParameter=BadgeForeground}"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="제목" Binding="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Width="*"
                                                    ElementStyle="{StaticResource TitleDataGridTextStyle}"/>
                                <DataGridCheckBoxColumn Header="활성" Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" Width="56">
                                    <DataGridCheckBoxColumn.ElementStyle>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <EventSetter Event="Click" Handler="DdayToggle_Click"/>
                                        </Style>
                                    </DataGridCheckBoxColumn.ElementStyle>
                                </DataGridCheckBoxColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0"
                Padding="0,8,0,0"
                Margin="0,10,0,0">
            <TextBlock Text="선택 후 Enter로 수정, Delete로 삭제"
                       FontSize="11"
                       Foreground="{StaticResource TextSubtleBrush}"
                       HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</Window>
