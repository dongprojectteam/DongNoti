<Window x:Class="DongNoti.Views.DdayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:DongNoti.Converters"
        Title="Dday"
        Height="320"
        Width="260"
        MinHeight="240"
        MinWidth="220"
        MaxWidth="340"
        WindowStartupLocation="Manual"
        Icon="/Resources/app.ico"
        Topmost="True"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Closing="Window_Closing"
        AllowsTransparency="False"
        Background="#F7F9FC"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <converters:CategoryColorConverter x:Key="CategoryColorConverter"/>

        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D7DEE8"/>
        <SolidColorBrush x:Key="PanelMutedTextBrush" Color="#697586"/>
        <SolidColorBrush x:Key="PanelHeadingBrush" Color="#1F2937"/>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="3,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2F80ED"/>
            <Setter Property="BorderBrush" Value="#66A8FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4895FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1C64C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DdayListBoxItemStyle" TargetType="ListBoxItem">
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DdayListBoxItem_PreviewMouseLeftButtonDown"/>
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="DdayListBoxItem_PreviewMouseRightButtonDown"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#EEF5FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#E7F0FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F7F9FC"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#1F5FA8"
                    Padding="9,6"
                    MouseDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="D-Day"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <Button x:Name="AddDdayButton"
                            Grid.Column="1"
                            Content="+"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="AddDdayButton_Click"
                            ToolTip="D-Day 등록"/>

                    <Button x:Name="CloseButton"
                            Grid.Column="2"
                            Content="×"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Background="#24476F"
                            BorderBrush="#3B638E"
                            Click="CloseButton_Click"
                            ToolTip="닫기"/>
                </Grid>
            </Border>

            <ListBox x:Name="DdayListBox"
                     Grid.Row="1"
                     SelectionMode="Single"
                     BorderThickness="0"
                     Background="Transparent"
                     ItemContainerStyle="{StaticResource DdayListBoxItemStyle}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.CanContentScroll="True"
                     SelectionChanged="DdayListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border HorizontalAlignment="Stretch"
                                Margin="5,3,5,2"
                                Padding="9,7"
                                CornerRadius="5"
                                Background="{Binding CategoryDisplay, Converter={StaticResource CategoryColorConverter}, ConverterParameter=Background}"
                                BorderBrush="{Binding CategoryDisplay, Converter={StaticResource CategoryColorConverter}, ConverterParameter=BorderBrush}"
                                BorderThickness="{Binding CategoryDisplay, Converter={StaticResource CategoryColorConverter}, ConverterParameter=BorderThickness}">
                            <StackPanel HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PanelHeadingBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DdayDisplayString}"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#1967D2"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DaysRemaining}" Value="0">
                                                        <Setter Property="Foreground" Value="#D92D20"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <TextBlock Text="{Binding TargetDate, StringFormat=yyyy-MM-dd}"
                                               FontSize="10"
                                               Foreground="{StaticResource PanelMutedTextBrush}"/>
                                    <TextBlock Text="{Binding DdayRepeatDisplay}"
                                               FontSize="10"
                                               Foreground="#8A95A4"
                                               FontStyle="Italic"
                                               Margin="7,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DdayRepeatDisplay}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding DdayYearsPassedDisplay}"
                                               FontSize="10"
                                               Foreground="#8A95A4"
                                               Margin="7,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DdayYearsPassedDisplay}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock x:Name="MemoTextBlock"
                                           Text="{Binding Memo}"
                                           FontSize="11"
                                           Foreground="{StaticResource PanelMutedTextBrush}"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap"
                                           MaxHeight="42"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel x:Name="EmptyStatePanel"
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed"
                        IsHitTestVisible="False">
                <TextBlock Text="D-Day"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#98A2B3"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="등록된 D-Day가 없습니다"
                           FontSize="12"
                           Foreground="#98A2B3"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
