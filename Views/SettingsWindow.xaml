<Window x:Class="DongNoti.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Height="640"
        Width="520"
        MinHeight="560"
        MinWidth="480"
        WindowStartupLocation="CenterOwner"
        Icon="/Resources/app.ico"
        ResizeMode="CanResizeWithGrip"
        Background="#F4F6F8"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DDE3EA"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextSubtleBrush" Color="#667085"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2F80ED"/>

        <Style x:Key="SectionPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#C9D2DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource ModernComboBoxStyle}">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="7,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="Transparent"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#F0F6FF"/>
                                <Setter Property="Foreground" Value="#1F6FD6"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#E7F0FF"/>
                                <Setter Property="Foreground" Value="#185ABC"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#98A2B3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="ListItemCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAFBFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F4F8FF"/>
                    <Setter Property="BorderBrush" Value="#B7D4FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1F6FD6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#185ABC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#2F80ED"/>
            <Setter Property="BorderBrush" Value="#B7D4FF"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F6FF"/>
                    <Setter Property="BorderBrush" Value="#82B8FF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#DCEBFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="#E9EEF5"
                                    BorderBrush="#DDE3EA"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Padding="3"
                                    HorizontalAlignment="Left">
                                <TabPanel IsItemsHost="True"
                                          Background="Transparent"
                                          KeyboardNavigation.TabIndex="1"/>
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSubtleBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabChrome"
                                Background="Transparent"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="#F8FBFF"/>
                                <Setter Property="Foreground" Value="#2F80ED"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1F2937"
                CornerRadius="6"
                Padding="14,10">
            <StackPanel>
                <TextBlock Text="설정"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="White"/>
                <TextBlock Text="앱 동작, 집중 모드, 데이터 관리를 조정합니다."
                           FontSize="11"
                           Foreground="#D1D9E6"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="0,10,0,0">
            <TabItem Header="일반">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,10,4,0">
                    <StackPanel>
                        <Border Style="{StaticResource SectionPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="앱 동작" Style="{StaticResource SectionTitleStyle}"/>
                                <CheckBox x:Name="RunOnStartupCheckBox"
                                          Content="Windows 시작 시 자동 실행"
                                          Checked="RunOnStartupCheckBox_Checked"
                                          Unchecked="RunOnStartupCheckBox_Unchecked"/>
                                <CheckBox x:Name="HideToTrayOnStartupCheckBox"
                                          Content="시작 시 트레이로 숨기기"/>
                                <CheckBox x:Name="MinimizeToTrayCheckBox"
                                          Content="닫기 시 트레이로 최소화"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="로그" Style="{StaticResource SectionTitleStyle}"/>
                                <CheckBox x:Name="EnableLoggingCheckBox"
                                          Content="로그 파일 생성"/>
                                <CheckBox x:Name="ShowUILogCheckBox"
                                          Content="UI 로그 창 표시"
                                          Checked="ShowUILogCheckBox_Checked"
                                          Unchecked="ShowUILogCheckBox_Unchecked"/>
                                <WrapPanel Margin="0,3,0,0">
                                    <Button Content="로그 저장"
                                            Click="FlushLogs_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,0,6,6"/>
                                    <Button Content="로그 열기"
                                            Click="OpenLogFile_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,0,6,6"/>
                                    <Button Content="데이터 폴더"
                                            Click="OpenDataFolder_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,0,8,6"/>
                                    <TextBlock x:Name="LogBufferCountText"
                                               Text="버퍼: 0개"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSubtleBrush}"
                                               VerticalAlignment="Center"
                                               Margin="2,0,0,6"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="알람 카테고리" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="알람과 D-Day를 분류할 카테고리와 색상을 관리합니다."
                                           Style="{StaticResource HintTextStyle}"
                                           Margin="0,0,0,10"/>
                                <DockPanel Margin="0,0,0,10">
                                    <Button DockPanel.Dock="Right"
                                            Content="초기화"
                                            Click="ResetCategories_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="6,0,0,0"/>
                                    <Button DockPanel.Dock="Right"
                                            Content="추가"
                                            Click="AddCategory_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="6,0,0,0"/>
                                    <TextBox x:Name="NewCategoryTextBox"/>
                                </DockPanel>
                                <ScrollViewer MaxHeight="210" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="CategoriesItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ListItemCardStyle}">
                                                    <Grid VerticalAlignment="Center">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="132"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextMainBrush}"
                                                                   VerticalAlignment="Center"/>
                                                        <ComboBox Grid.Column="1"
                                                                  ItemsSource="{Binding CategoryColorOptionsList, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  DisplayMemberPath="Display"
                                                                  SelectedValuePath="Value"
                                                                  SelectedValue="{Binding Color, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  SelectionChanged="CategoryColor_SelectionChanged"
                                                                  Margin="8,0"
                                                                  VerticalAlignment="Center"/>
                                                        <Button Grid.Column="2"
                                                                Content="삭제"
                                                                Click="DeleteCategory_Click"
                                                                MinWidth="52"
                                                                VerticalAlignment="Center"
                                                                Tag="{Binding Name}">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Name}" Value="기본">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="집중">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,10,4,0">
                    <Border Style="{StaticResource SectionPanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="집중 모드 프리셋" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="빠른 실행에 사용할 시간 프리셋을 관리합니다."
                                               Style="{StaticResource HintTextStyle}"/>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="추가"
                                            Click="AddPreset_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="8,0,0,0"/>
                                    <Button Content="초기화"
                                            Click="ResetPresets_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="6,0,0,0"/>
                                </StackPanel>
                            </DockPanel>

                            <ScrollViewer Grid.Row="1" MaxHeight="390" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="PresetsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource ListItemCardStyle}"
                                                    Padding="10,8">
                                                <Grid VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <RadioButton Grid.Column="0"
                                                                 IsChecked="{Binding IsDefault, Mode=TwoWay}"
                                                                 Checked="DefaultPreset_Checked"
                                                                 Margin="0,0,10,0"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 GroupName="DefaultPreset"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextMainBrush}"/>
                                                        <TextBlock Text="{Binding Minutes, StringFormat={}{0}분}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource TextSubtleBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2"
                                                               Text="기본"
                                                               FontSize="10"
                                                               Foreground="#2F80ED"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Margin="8,0,12,0"
                                                               Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <Button Grid.Column="3"
                                                            Content="삭제"
                                                            Click="DeletePreset_Click"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            MinWidth="52"
                                                            VerticalAlignment="Center"
                                                            Tag="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock Grid.Row="2"
                                       Text="라디오 버튼으로 기본 프리셋을 선택합니다."
                                       Style="{StaticResource HintTextStyle}"
                                       Margin="0,6,0,0"/>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="데이터">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,10,4,0">
                    <StackPanel>
                        <Border Style="{StaticResource SectionPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="백업 / 복원" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="알람과 D-Day 데이터를 파일로 내보내거나 가져옵니다."
                                           Style="{StaticResource HintTextStyle}"
                                           Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="내보내기"
                                            Click="ExportAlarms_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            MinWidth="100"
                                            Margin="0,0,8,0"/>
                                    <Button Content="가져오기"
                                            Click="ImportAlarms_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            MinWidth="100"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="정보" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="VersionTextBlock"
                                           Text="DongNoti v1.0.5.6"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMainBrush}"/>
                                <TextBlock Text="Windows 알람 프로그램"
                                           Style="{StaticResource HintTextStyle}"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="© 2026 DongNoti"
                                           FontSize="10"
                                           Foreground="#98A2B3"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0"
                Padding="0,10,0,0"
                Margin="0,10,0,0">
            <Grid>
                <Button Content="단축키"
                        Click="KeyboardShortcuts_Click"
                        HorizontalAlignment="Left"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="74"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="확인"
                            Click="OK_Click"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button Content="취소"
                            Click="Cancel_Click"
                            IsCancel="True"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
